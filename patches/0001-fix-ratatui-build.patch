+#[no_mangle]
+pub extern "C" fn ratatui_poll_event(eventPtr: *mut i64, timeoutMs: i32) -> i32 {
+    // Poll for keyboard events using crossterm
+    use crossterm::event::{poll, read, Event, KeyCode, KeyModifiers};
+    use std::time::Duration;
+
+    if eventPtr.is_null() {
+        return -1;
+    }
+
+    let timeout = if timeoutMs > 0 {
+        Duration::from_millis(timeoutMs as u64)
+    } else {
+        Duration::from_secs(0)
+    };
+
+    unsafe {
+        match poll(timeout) {
+            Ok(true) => match read() {
+                Ok(Event::Key(key)) => {
+                    // Store event info in a heap-allocated struct and return a handle
+                    // For now: 0 = no event, 1 = event available
+                    // In practice this would store event data in a more complex structure
+                    *eventPtr = 1; // Signal event available
+                    1
+                },
+                Ok(Event::Resize(w, h)) => {
+                    *eventPtr = 1;
+                    1
+                },
+                _ => {
+                    *eventPtr = 0;
+                    0
+                }
+            },
+            Ok(false) => 0,
+            Err(_) => -1,
+        }
+    }
+}
